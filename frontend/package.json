    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "postcss": "^8.5.6",
